# Google AI Studio で取得した API キーを貼る（https://aistudio.google.com/apikey）
GEMINI_API_KEY=ここにAPIキー

# 使うモデル（うまく動かないときはここを差し替える）
# 候補: gemini-3.1-flash-live-preview（連続音声OK・推奨） / gemini-2.5-flash-native-audio-latest
GEMINI_MODEL=gemini-3.1-flash-live-preview

# AIの声（Aoede / Puck / Charon / Kore / Fenrir）
GEMINI_VOICE=Aoede

PORT=3000
